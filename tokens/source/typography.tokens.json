{
  "typography": {
    "eyebrow": {
      "$description": "Accent uppercase label; used by .eyebrow utility class, .label utility class, trip-dashboard kickers, planner item time markers",
      "fontSize": {
        "$type": "dimension",
        "$value": "11px"
      },
      "fontWeight": {
        "$type": "number",
        "$value": 900
      },
      "letterSpacing": {
        "$type": "dimension",
        "$value": "0.18em"
      },
      "lineHeight": {
        "$type": "number",
        "$value": 1.15
      },
      "textTransform": {
        "$type": "string",
        "$value": "uppercase"
      }
    },

    "label": {
      "$description": "Form field label style. Distinct from the .eyebrow/.label CSS utility class which uses 11px; form labels use 12px with tighter letter-spacing",
      "fontSize": {
        "$type": "dimension",
        "$value": "12px"
      },
      "fontWeight": {
        "$type": "number",
        "$value": 900
      },
      "letterSpacing": {
        "$type": "dimension",
        "$value": "0.08em"
      },
      "lineHeight": {
        "$type": "number",
        "$value": 1.2
      },
      "textTransform": {
        "$type": "string",
        "$value": "uppercase"
      }
    },

    "caption": {
      "$description": "Secondary and muted text; .muted, .day-tile__summary, .screen-header__meta, planner item body paragraphs",
      "fontSize": {
        "$type": "dimension",
        "$value": "13px"
      },
      "fontWeight": {
        "$type": "number",
        "$value": 700
      },
      "lineHeight": {
        "$type": "number",
        "$value": 1.35
      }
    },

    "action": {
      "$description": "Bold interactive text; button text, action-bar title, form action labels. Dominant 14px pattern in the UI — always heavy weight",
      "fontSize": {
        "$type": "dimension",
        "$value": "14px"
      },
      "fontWeight": {
        "$type": "number",
        "$value": 900
      },
      "lineHeight": {
        "$type": "number",
        "$value": 1.5
      }
    },

    "heading": {
      "$description": "Card-level headings; dashboard-card strong, trip-card name, planner-item strong, day-tile h2 in dashboard context",
      "fontSize": {
        "$type": "dimension",
        "$value": "1rem"
      },
      "fontWeight": {
        "$type": "number",
        "$value": 900
      },
      "lineHeight": {
        "$type": "number",
        "$value": 1.15
      }
    },

    "section": {
      "$description": "Panel and modal section headings; modal-sheet h2, settings-panel h2, empty-state h2",
      "fontSize": {
        "$type": "dimension",
        "$value": "1.35rem"
      },
      "fontWeight": {
        "$type": "number",
        "$value": 900
      },
      "lineHeight": {
        "$type": "number",
        "$value": 1.05
      }
    },

    "title": {
      "$description": "Screen-level h1; .screen-header h1, .auth-panel h1, .trip-dashboard-header h1",
      "fontSize": {
        "$type": "string",
        "$value": "clamp(1.8rem, 6vw, 2.55rem)",
        "$description": "Fluid type scale. $type is string to prevent Style Dictionary from applying dimension transforms to the clamp() function"
      },
      "fontWeight": {
        "$type": "number",
        "$value": 900
      },
      "lineHeight": {
        "$type": "number",
        "$value": 0.98
      }
    }
  }
}
