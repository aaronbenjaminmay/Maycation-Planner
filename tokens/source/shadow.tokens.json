{
  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "10px",
        "blur": "28px",
        "spread": "0",
        "color": "rgba(0, 0, 0, 0.34)"
      },
      "$description": "Small shadow primitive. Semantic alias: --shadow-surface-card"
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "18px",
        "blur": "50px",
        "spread": "0",
        "color": "rgba(0, 0, 0, 0.26)"
      },
      "$description": "Panel shadow primitive — matches rendered §5 panel surface shadow. Semantic alias: --shadow-surface-panel"
    },
    "lg": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "18px",
        "blur": "50px",
        "spread": "0",
        "color": "rgba(0, 0, 0, 0.28)"
      },
      "$description": "Large shadow primitive. Semantic alias: --shadow-surface-overlay"
    },
    "surface": {
      "card": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0",
          "offsetY": "10px",
          "blur": "28px",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0.34)"
        },
        "$description": "Shadow for component cards: dashboard-card, trip-card, day-tile, planner-item-card. Semantic alias for shadow.sm."
      },
      "panel": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0",
          "offsetY": "18px",
          "blur": "50px",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0.26)"
        },
        "$description": "Shadow for panel surfaces: card-surface, modal-sheet, auth-panel, dashboard-panel. Value matches rendered production shadow (0 18px 50px 0 rgba(0,0,0,0.26)). Semantic alias for shadow.md."
      },
      "overlay": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0",
          "offsetY": "18px",
          "blur": "50px",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0.28)"
        },
        "$description": "Ambient shadow; matches the CSS --shadow variable value. Semantic alias for shadow.lg."
      }
    }
  }
}
